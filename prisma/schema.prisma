// =============================================================================
// Dafa Sales Management App - Prisma Schema
// Vietnamese Glass Construction Company - Sales Pipeline & CRM
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

// User String within the organization


// Current employment/availability status of a user


// Classification of customer type


// Customer lifecycle status in the sales pipeline


// Channel through which the customer was acquired


// Glass product category grouping


// Unit of measurement for products


// Sales opportunity pipeline stage


// Quotation lifecycle status


// Order fulfillment status


// Payment collection status for an order


// Type of task/activity for sales follow-up


// Task urgency level


// Task completion status


// Type of interaction/touchpoint with a customer


// =============================================================================
// MODELS
// =============================================================================

// Sales team / regional group
model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users User[]
}

// System user (admin, manager, or sales staff)
model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String
  phone     String?
  role      String       @default("SALES")
  teamId    String?
  status    String @default("ACTIVE")
  avatar    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  team                 Team?                 @relation(fields: [teamId], references: [id], onDelete: SetNull)
  customers            Customer[]
  opportunities        Opportunity[]
  quotes               Quote[]
  orders               Order[]
  tasksAssigned        Task[]                @relation("TaskAssignedTo")
  tasksCreated         Task[]                @relation("TaskCreatedBy")
  kpis                 KPI[]
  interactions         CustomerInteraction[]
  orderPaymentsCreated OrderPayment[]
  auditLogs            AuditLog[]
  trips                BusinessTrip[]
}

// Customer / lead in the CRM
model Customer {
  id               String         @id @default(cuid())
  code             String         @unique // Format: KH-XXXXXX
  type             String 
  name             String
  contactPerson    String?
  phone            String?
  email            String?
  address          String?
  province         String?
  projectName      String?
  source           String 
  assignedToId     String
  status           String @default("NEW")
  productNeeds     String?
  estimatedArea    Float?
  estimatedBudget  Float?
  notes            String?
  nextFollowUpDate DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?      // Soft delete

  // Relations
  assignedTo    User                  @relation(fields: [assignedToId], references: [id], onDelete: Cascade)
  interactions  CustomerInteraction[]
  opportunities Opportunity[]
  quotes        Quote[]
  orders        Order[]
  tasks         Task[]

  @@index([phone])
  @@index([email])
  @@index([status])
  @@index([assignedToId])
  @@index([code])
}

// Record of a single interaction/touchpoint with a customer
model CustomerInteraction {
  id               String          @id @default(cuid())
  customerId       String
  userId           String
  type             String 
  content          String
  result           String?
  nextFollowUpDate DateTime?
  createdAt        DateTime        @default(now())

  // Relations
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Sales opportunity / deal in the pipeline
model Opportunity {
  id                String           @id @default(cuid())
  code              String           @unique // Format: CH-XXXXXX
  name              String
  customerId        String
  projectName       String?
  assignedToId      String
  products          String?
  estimatedArea     Float?
  estimatedValue    Float            @default(0)
  probability       Int              @default(50) // 0-100
  stage             String @default("NEW_LEAD")
  expectedCloseDate DateTime?
  lossReason        String?
  competitor        String?
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?        // Soft delete

  // Relations
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedTo User     @relation(fields: [assignedToId], references: [id], onDelete: Cascade)
  quotes     Quote[]
  orders     Order[]
  tasks      Task[]

  @@index([stage])
  @@index([assignedToId])
}

// Glass product in the catalog
model Product {
  id             String       @id @default(cuid())
  code           String       @unique
  name           String
  group          String 
  unit           String  @default("SQM")
  referencePrice Float        @default(0)
  description    String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?    // Soft delete

  // Relations
  quoteItems QuoteItem[]
  orderItems OrderItem[]

  @@index([group])
  @@index([code])
}

// Price quotation sent to a customer
model Quote {
  id               String      @id @default(cuid())
  code             String      @unique // Format: BG-XXXXXX
  customerId       String
  opportunityId    String?
  createdById      String
  status           String @default("DRAFT")
  expiryDate       DateTime?
  shippingCost     Float       @default(0)
  installationCost Float       @default(0)
  vatRate          Float       @default(10)
  subtotal         Float       @default(0)
  vatAmount        Float       @default(0)
  total            Float       @default(0)
  terms            String?
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  deletedAt        DateTime?   // Soft delete

  // Relations
  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  createdBy   User        @relation(fields: [createdById], references: [id], onDelete: Cascade)
  items       QuoteItem[]
  orders      Order[]

  @@index([status])
  @@index([createdById])
}

// Individual line item within a quote
model QuoteItem {
  id            String   @id @default(cuid())
  quoteId       String
  productId     String?
  description   String
  specification String?  // Glass specification details
  thickness     String?
  length        Float?
  width         Float?
  area          Float?
  quantity      Int      @default(1)
  unitPrice     Float    @default(0)
  discount      Float    @default(0)
  total         Float    @default(0)
  sortOrder     Int      @default(0)

  // Relations
  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

// Confirmed sales order
model Order {
  id                   String        @id @default(cuid())
  code                 String        @unique // Format: DH-XXXXXX
  customerId           String
  opportunityId        String?
  quoteId              String?
  assignedToId         String
  projectName          String?
  status               String   @default("NEW")
  paymentStatus String @default("UNPAID")
  subtotal             Float         @default(0)
  discount             Float         @default(0)
  vatRate              Float         @default(10)
  vatAmount            Float         @default(0)
  total                Float         @default(0)
  paidAmount           Float         @default(0)
  remainingAmount      Float         @default(0)
  signedDate           DateTime?
  expectedDeliveryDate DateTime?
  notes                String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  deletedAt            DateTime?     // Soft delete

  // Relations
  customer    Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  quote       Quote?       @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  assignedTo  User         @relation(fields: [assignedToId], references: [id], onDelete: Cascade)
  items       OrderItem[]
  payments    OrderPayment[]

  @@index([status])
  @@index([paymentStatus])
  @@index([assignedToId])
}

// Individual line item within an order
model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  productId     String?
  description   String
  specification String?
  thickness     String?
  length        Float?
  width         Float?
  area          Float?
  quantity      Int      @default(1)
  unitPrice     Float    @default(0)
  discount      Float    @default(0)
  total         Float    @default(0)
  sortOrder     Int      @default(0)

  // Relations
  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

// Payment record against an order
model OrderPayment {
  id          String   @id @default(cuid())
  orderId     String
  amount      Float
  paymentDate DateTime
  method      String?  // e.g. cash, transfer, check
  reference   String?
  notes       String?
  createdById String
  createdAt   DateTime @default(now())

  // Relations
  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdBy User  @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

// Sales task / follow-up activity
model Task {
  id            String       @id @default(cuid())
  title         String
  customerId    String?
  opportunityId String?
  assignedToId  String
  createdById   String
  type          String 
  dueDate       DateTime
  priority      String @default("MEDIUM")
  status        String   @default("TODO")
  notes         String?
  completedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Relations
  customer    Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  assignedTo  User         @relation("TaskAssignedTo", fields: [assignedToId], references: [id], onDelete: Cascade)
  createdBy   User         @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([assignedToId])
  @@index([dueDate])
}

// Monthly KPI targets and actuals for sales staff
model KPI {
  id                 String @id @default(cuid())
  userId             String
  month              Int
  year               Int
  targetRevenue      Float  @default(0)
  targetNewCustomers Int    @default(0)
  targetInteractions Int    @default(0)
  actualRevenue      Float  @default(0)
  actualNewCustomers Int    @default(0)
  actualInteractions Int    @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
}

// Application-level key-value settings
model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Audit trail for tracking user actions
model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entity])
  @@index([entityId])
  @@index([userId])
}

// Business Trip (Công tác)
model BusinessTrip {
  id              String   @id @default(cuid())
  code            String   @unique // CT-XXXXXX
  userId          String
  title           String
  destination     String
  purpose         String?
  startDate                  DateTime
  endDate                    DateTime
  estimatedCost              Float    @default(0)
  estimatedTransportCost     Float    @default(0)
  estimatedFoodCost          Float    @default(0)
  estimatedAccommodationCost Float    @default(0)
  estimatedEntertainmentCost Float    @default(0)
  entertainmentNotes         String?
  actualCost                 Float    @default(0)
  actualTransportCost        Float    @default(0)
  actualFoodCost             Float    @default(0)
  actualAccommodationCost    Float    @default(0)
  actualEntertainmentCost    Float    @default(0)
  status                     String   @default("PROPOSED") // PROPOSED, APPROVED, REJECTED, IN_PROGRESS, COMPLETED
  notes           String?
  summary         String?
  totalNewClients Int      @default(0)
  totalOldClients Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports TripDailyReport[]

  @@index([userId])
  @@index([status])
}

// Daily Report for Business Trip
model TripDailyReport {
  id              String   @id @default(cuid())
  tripId          String
  date            DateTime
  location        String?  // GPS Coordinates or Link
  content         String
  results         String?
  newClients      Int      @default(0)
  oldClients      Int      @default(0)
  images          String?  // JSON string array of URLs
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  trip BusinessTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

